# Maintainer: Gakuseei <erikschaefer07@icloud.com>

pkgname=rishot-git
pkgver=r8
pkgrel=1
pkgdesc="Wayland screenshot and annotation overlay built on Quickshell"
arch=('any')
url="https://github.com/Gakuseei/rishot"
license=('MIT')
depends=('quickshell' 'wl-clipboard' 'qt6-declarative' 'qt6-svg' 'qt6-5compat' 'qt6-wayland')
optdepends=('imagemagick: stitch a multi-monitor capture into one image'
            'cliphist: record copied shots into clipboard history'
            'curl: upload captures'
            'kdialog: native save-as file dialog')
provides=('rishot')
conflicts=('rishot')
makedepends=('git')
source=("$pkgname::git+https://github.com/Gakuseei/rishot.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/$pkgname"
	# Prefer a tag-based version; fall back to rev-count + short sha for an
	# untagged tree.
	if git describe --long --tags >/dev/null 2>&1; then
		git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
	else
		printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
	fi
}

package() {
	cd "$srcdir/$pkgname"

	# Quickshell config tree → /usr/share/rishot/src (resolved by bin/rishot).
	find src -type f | while read -r f; do
		install -Dm644 "$f" "$pkgdir/usr/share/rishot/$f"
	done

	install -Dm755 bin/rishot "$pkgdir/usr/bin/rishot"
	install -Dm644 rishot.desktop "$pkgdir/usr/share/applications/rishot.desktop"

	if [ -f README.md ]; then
		install -Dm644 README.md "$pkgdir/usr/share/doc/rishot/README.md"
	fi
	if [ -f LICENSE ]; then
		install -Dm644 LICENSE "$pkgdir/usr/share/licenses/rishot/LICENSE"
	fi
}
